<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Media Kit — DRYVE®</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,800;0,900;1,700&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    /* MANTENDO TODA A PARTE VISUAL ORIGINAL */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --orange: #F06B28; --orange-dark: #C9521A; --orange-light:#FFF0E8;
      --teal: #00B4AE; --teal-dark: #008C87; --teal-light: #E0F7F6;
      --black: #111111; --gray: #6B6B6B; --light: #F5F4F2; --white: #FFFFFF;
      --border: rgba(17,17,17,0.1); --font-d: 'Barlow Condensed', sans-serif; --font-b: 'Barlow', sans-serif;
    }
    body { background: var(--white); color: var(--black); font-family: var(--font-b); line-height: 1.6; overflow-x: hidden; }
    
    /* NAV */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 200; display: flex; align-items: center; justify-content: space-between; padding: 1.1rem 5vw; background: rgba(255,255,255,0.92); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); }
    .logo-word { font-family: var(--font-d); font-size: 2rem; font-weight: 900; color: var(--teal); text-decoration: none; }
    
    /* HERO */
    #hero-banner { min-height: 80vh; padding-top: 100px; background: var(--black); position: relative; overflow: hidden; display: flex; align-items: center; }
    .hb-inner { position: relative; z-index: 3; padding: 5rem 5vw; width: 100%; }
    .hb-name { font-family: var(--font-d); font-weight: 900; font-size: 1.5rem; color: rgba(255,255,255,0.45); text-transform: uppercase; }
    .hb-title { font-family: var(--font-d); font-weight: 900; font-size: clamp(3.5rem, 7vw, 7.5rem); line-height: 0.88; text-transform: uppercase; color: #fff; margin: 1rem 0; }
    .c-or { color: var(--orange); }

    /* NOVA SEÇÃO: LINK TREE */
    .linktree-section { padding: 2rem 5vw; background: var(--black); display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
    .lt-btn { 
        display: flex; align-items: center; gap: 1rem; width: 100%; max-width: 400px; 
        padding: 0.8rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px; color: #fff; text-decoration: none; font-family: var(--font-d);
        font-weight: 700; text-transform: uppercase; transition: 0.3s;
    }
    .lt-btn:hover { background: var(--orange); transform: translateX(10px); }
    .lt-icon { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; background: var(--teal); display: flex; align-items: center; justify-content: center; }

    /* ESTILO DAS SEÇÕES ORIGINAIS (REDUZIDO PARA CABER) */
    section { padding: 5rem 5vw; }
    .sh { font-family: var(--font-d); font-weight: 900; font-size: clamp(2.4rem, 4.5vw, 4.2rem); text-transform: uppercase; }
    .met-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-top: 2rem; }
    .met-card { background: #1a1a1a; padding: 2rem; border-radius: 8px; color: #fff; }
    .met-val { font-family: var(--font-d); font-size: 3rem; font-weight: 900; color: var(--orange); }
    
    .sobre-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
    .sobre-img { width: 100%; border-radius: 12px; border: 4px solid var(--orange); }

    @media (max-width: 768px) { .sobre-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>

  <nav>
    <a href="#" class="logo-word">DRYVE®</a>
    <span style="font-family: var(--font-d); font-weight: 800; color: var(--orange);">MEDIA KIT</span>
  </nav>

  <section id="hero-banner">
    <div class="hb-inner">
      <p class="hb-name" id="js-handle">@CARREGANDO</p>
      <h1 class="hb-title" id="js-hero-title">TITULO<br><span class="c-or">CARREGANDO</span></h1>
      
      <div id="js-linktree" class="linktree-section" style="padding-left: 0;">
        </div>
    </div>
  </section>

  <section id="sobre">
    <div class="sobre-grid">
      <img id="js-sobre-img" src="" alt="Influencer" class="sobre-img">
      <div>
        <h2 class="sh">SOBRE <span class="c-or">MIM</span></h2>
        <p id="js-sobre-bio" style="margin: 1.5rem 0; color: var(--gray);"></p>
        <div id="js-tags" style="display: flex; gap: 0.5rem; flex-wrap: wrap;"></div>
      </div>
    </div>
  </section>

  <section id="metricas" style="background: var(--black); color: #fff;">
    <h2 class="sh">MÉTRICAS <span class="c-or">REAIS</span></h2>
    <div class="met-grid" id="js-metrics-grid">
      </div>
  </section>

  <script>
    /* ============================================================
       CONFIGURAÇÕES — EDITE APENAS ESTE BLOCO
    ============================================================ */
    const CONFIG = {
      // Perfil Básico
      handle: "@_vinilozano",
      heroTitle: "WELLNESS<br><span class='c-or'>E PERFORMANCE</span>",
      sobreImg: "https://github.com/usuario/repo/raw/main/fotos/perfil.jpg", 
      sobreBio: "Aqui você escreve sua história. Focado em transformar vidas através do esporte e nutrição desde 2018.",
      tags: ["Corrida", "Maratona", "Lifestyle", "Saúde"],

      // Seção Link Tree
      links: [
        { 
          label: "Clube Strava", 
          url: "strava.app.link/a5D168uvz0b", 
          thumb: "https://iconscout.com/free-icon/free-strava-logo-icon_3031661" // Pode ser URL de foto ou ícone
        },
        { 
          label: "LIQUIDZ", 
          url: "go.liquidz.com.br/ec/VINI10", 
          thumb: "https://cdn-icons-png.flaticon.com/512/174/174855.png" 
        },
        { 
          label: "WhatsApp Parcerias", 
          url: "https://wa.me/...", 
          thumb: "https://cdn-icons-png.flaticon.com/512/733/733585.png" 
        }
      ],

      // Métricas (Manuais)
      metrics: [
        { label: "Seguidores", value: "9.6k", icon: "👥" },
        { label: "Vizualizações", value: "717,8 mil", icon: "🔥" },
        { label: "Interações", value: "64,5 mil", icon: "👁️" },
        { label: "Engajamento", value: "8.7%", icon: "📊" }
      ]
    };

    /* ============================================================
       LÓGICA DE ALIMENTAÇÃO (NÃO PRECISA EDITAR ABAIXO)
    ============================================================ */
    function initSite() {
      // Hero & Perfil
      document.getElementById('js-handle').textContent = CONFIG.handle;
      document.getElementById('js-hero-title').innerHTML = CONFIG.heroTitle;
      document.getElementById('js-sobre-img').src = CONFIG.sobreImg;
      document.getElementById('js-sobre-bio').textContent = CONFIG.sobreBio;

      // Link Tree
      const ltContainer = document.getElementById('js-linktree');
      CONFIG.links.forEach(link => {
        ltContainer.innerHTML += `
          <a href="${link.url}" target="_blank" class="lt-btn">
            <img src="${link.thumb}" class="lt-icon" onerror="this.style.display='none'">
            <span>${link.label}</span>
          </a>
        `;
      });

      // Tags
      const tagContainer = document.getElementById('js-tags');
      CONFIG.tags.forEach(tag => {
        tagContainer.innerHTML += `<span style="background:var(--orange-light); color:var(--orange); padding: 5px 15px; border-radius: 20px; font-weight: bold; font-size: 0.8rem;">${tag}</span>`;
      });

      // Métricas
      const metContainer = document.getElementById('js-metrics-grid');
      CONFIG.metrics.forEach(m => {
        metContainer.innerHTML += `
          <div class="met-card">
            <div style="font-size: 1.5rem; margin-bottom: 0.5rem;">${m.icon}</div>
            <div class="met-val">${m.value}</div>
            <div style="text-transform: uppercase; font-family: var(--font-d); color: rgba(255,255,255,0.5);">${m.label}</div>
          </div>
        `;
      });
    }

    window.onload = initSite;
  </script>
</body>
</html>
